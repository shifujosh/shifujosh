%%{init: {'theme': 'base', 'themeVariables': { 'darkMode': true, 'background': 'transparent', 'primaryColor': '#1e293b', 'edgeLabelBackground':'#0f172a', 'fontSize': '15px', 'fontFamily': 'Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif' }, 'flowchart': { 'rankSpacing': 60, 'nodeSpacing': 25, 'curve': 'basis' } }}%%
graph TB
    %% Styling
    classDef actor fill:#000000,stroke:#fff,stroke-width:2px,color:#fff,font-weight:bold;
    classDef hub fill:#0f172a,stroke:#2dd4bf,stroke-width:3px,color:#fff,font-weight:bold;
    classDef usecase fill:#1e293b,stroke:#64748b,stroke-width:1px,color:#94a3b8;
    classDef outcome fill:#1e1b4b,stroke:#6366f1,stroke-width:2px,color:#c7d2fe,font-weight:bold;

    %% Me at the top
    Me((Architect)):::actor

    %% Central System
    JACQ[<b>JACQ</b><br/><i>Cognitive Operating System</i>]:::hub

    %% Use Cases (Problems I Solve)
    subgraph UseCases [Problems I Solve]
        direction TB
        style UseCases fill:none,stroke:#64748b,stroke-width:1px,stroke-dasharray: 5 5,color:#94a3b8
        UC1(Context Amnesia<br/><i>AI forgets everything</i>):::usecase
        UC2(Hallucination Risk<br/><i>LLMs invent facts</i>):::usecase
        UC3(Data Chaos<br/><i>Bad inputs break systems</i>):::usecase
    end

    %% Outcomes (Results I Drive)
    subgraph Results [Results I Drive]
        direction TB
        style Results fill:#000000,fill-opacity:0.3,stroke:#6366f1,stroke-width:1px,stroke-dasharray: 5 5,color:#e0e7ff
        R1(<b>Persistent Memory</b><br/>Entity-Fact Graph):::outcome
        R2(<b>Verified Outputs</b><br/>Truth Before Publish):::outcome
        R3(<b>Data Physics</b><br/>Schema as Contract):::outcome
    end

    %% Flow
    Me ==> JACQ
    JACQ --> UC1
    JACQ --> UC2
    JACQ --> UC3
    UC1 ==> R1
    UC2 ==> R2
    UC3 ==> R3

    %% Styling
    linkStyle default stroke-width:2px,fill:none,stroke:#64748b
    linkStyle 4 stroke:#2dd4bf,stroke-width:3px
    linkStyle 5 stroke:#2dd4bf,stroke-width:3px
    linkStyle 6 stroke:#2dd4bf,stroke-width:3px
