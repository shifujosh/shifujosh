%%{init: {'theme': 'base', 'themeVariables': { 'darkMode': true, 'background': 'transparent', 'primaryColor': '#1e293b', 'edgeLabelBackground':'#0f172a', 'fontSize': '16px', 'fontFamily': 'Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif' }, 'flowchart': { 'rankSpacing': 100, 'nodeSpacing': 60, 'curve': 'monotoneY', 'padding': 20 } }}%%
graph TB
    %% Styling
    classDef actor fill:#000000,stroke:#fff,stroke-width:2px,color:#fff,font-weight:bold;
    classDef hub fill:#0f172a,stroke:#2dd4bf,stroke-width:3px,color:#fff,font-weight:bold;
    classDef usecase fill:#1e293b,stroke:#64748b,stroke-width:1px,color:#94a3b8;
    classDef outcome fill:#1e1b4b,stroke:#6366f1,stroke-width:2px,color:#c7d2fe,font-weight:bold;

    %% Me at the top
    Me((Architect)):::actor

    %% Central System (Renamed)
    Hub[<b>Cognitive</b><br/><b>Operating System</b>]:::hub

    %% Use Cases (Problems) - Stronger Language
    subgraph UseCases [Problems I Solve]
        direction TB
        style UseCases fill:none,stroke:#64748b,stroke-width:1px,stroke-dasharray: 5 5,color:#94a3b8
        UC1(<b>Context Amnesia</b><br/><i>Resets to zero</i>):::usecase
        UC2(<b>Model Hallucination</b><br/><i>Probabilistic guessing</i>):::usecase
        UC3(<b>Data Entropy</b><br/><i>Chaos in, chaos out</i>):::usecase
        UC4(<b>Orchestration Drift</b><br/><i>Agents lose the plot</i>):::usecase
    end

    %% Outcomes (Results) - Stronger Language
    subgraph Results [Results I Drive]
        direction TB
        style Results fill:#000000,fill-opacity:0.3,stroke:#6366f1,stroke-width:1px,stroke-dasharray: 5 5,color:#e0e7ff
        R1(<b>Compound Intelligence</b><br/><i>Context that scales</i>):::outcome
        R2(<b>Deterministic Verification</b><br/><i>Logic over probability</i>):::outcome
        R3(<b>Data Physics</b><br/><i>Strict laws for data</i>):::outcome
        R4(<b>Agentic Interfaces</b><br/><i>UX that steers intent</i>):::outcome
    end

    %% Flow
    Me ==> Hub
    Hub --> UC1
    Hub --> UC2
    Hub --> UC3
    Hub --> UC4
    UC1 ==> R1
    UC2 ==> R2
    UC3 ==> R3
    UC4 ==> R4

    %% Styling
    linkStyle default stroke-width:2px,fill:none,stroke:#64748b
    linkStyle 4 stroke:#2dd4bf,stroke-width:3px
    linkStyle 5 stroke:#2dd4bf,stroke-width:3px
    linkStyle 6 stroke:#2dd4bf,stroke-width:3px
