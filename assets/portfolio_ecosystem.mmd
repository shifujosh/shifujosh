%%{init: {'theme': 'base', 'themeVariables': { 'darkMode': true, 'background': 'transparent', 'primaryColor': '#1e293b', 'edgeLabelBackground':'#0f172a', 'fontSize': '16px', 'fontFamily': 'Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif' }, 'flowchart': { 'rankSpacing': 40, 'nodeSpacing': 20, 'curve': 'basis' } }}%%
graph TD
    %% Styling - Minimalist Dark Mode with Frontier Accents
    %% Hub: Central OS
    classDef hub fill:#0f172a,stroke:#2dd4bf,stroke-width:3px,color:#fff,font-weight:bold;
    %% Shared: Wisdom/Memory
    classDef wisdom fill:#0f172a,stroke:#fbbf24,stroke-width:2px,color:#fbbf24,stroke-dasharray: 2 2;
    %% Actor: User
    classDef actor fill:#000000,stroke:#fff,stroke-width:2px,color:#fff,font-weight:bold;
    %% Input: Context
    classDef input fill:#0f172a,stroke:#64748b,stroke-width:1px,color:#94a3b8,stroke-dasharray: 2 2;
    %% Frontier: Multimodal outputs
    classDef frontier fill:#1e1b4b,stroke:#6366f1,stroke-width:2px,color:#c7d2fe;
    %% Learning Loop
    classDef loop fill:#1e293b,stroke:#10b981,stroke-width:2px,color:#6ee7b7;

    %% 1. Inputs - Top Level
    User((Human Operator)):::actor
    World(World Context):::input

    %% 2. The Core
    JACQ(<b>JACQ</b><br/><i>Cognitive Operating System</i><hr/>The Agent <b>Chatbot</b><br/>The Loom <b>Engine</b><br/>Magic Canvas <b>GUI</b>):::hub

    %% 3. Multimodal Output Engine (Simplified)
    subgraph Outputs [Multimodal Creation Engine]
        direction LR
        style Outputs fill:none,stroke:#6366f1,stroke-width:1px,stroke-dasharray: 5 5,color:#818cf8
        Text(Text & Code):::frontier
        Visuals(Art & Visuals):::frontier
        Media(Video & Media):::frontier
        Data(Data & Insights):::frontier
    end
    
    %% 4. The Virtuous Cycle
    Learning{Adaptive Learning<br/><i>Quality Loop</i>}:::loop
    Wisdom[Shared Wisdom<br/><i>Artifacts / Memories</i>]:::wisdom

    %% Connection Logic - Vertical Flow
    User ==>|Intent| JACQ
    World -.->|Context| JACQ
    
    %% JACQ Direct to Outputs (Skipping Infra)
    JACQ ==>|Orchestrates| Text
    JACQ ==>|Orchestrates| Visuals
    JACQ ==>|Orchestrates| Media
    JACQ ==>|Orchestrates| Data
    
    %% Force Output Alignment
    Text ~~~ Visuals ~~~ Media ~~~ Data
    
    %% The Adaptive Loop
    Text --> Learning
    Visuals --> Learning
    Media --> Learning
    Data --> Learning
    
    %% Human in the Loop
    User -.->|Feedback| Learning
    
    Learning ==>|Refines| Wisdom
    Wisdom -.->|Augments| JACQ

    %% Layout - Explicit Link Styling
    linkStyle default stroke-width:2px,fill:none,stroke:#64748b
    
    %% Highlight Feedback (Green) and Wisdom (Yellow) Loops
    linkStyle 13 stroke:#10b981,stroke-width:3px,color:#10b981
    linkStyle 15 stroke:#fbbf24,stroke-width:3px,color:#fbbf24
