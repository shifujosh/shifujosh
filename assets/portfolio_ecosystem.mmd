graph TD
    %% Styling - Minimalist Dark Mode
    classDef hub fill:#0f172a,stroke:#2dd4bf,stroke-width:3px,color:#fff;
    classDef app fill:#1e293b,stroke:#38bdf8,stroke-width:2px,color:#e2e8f0;
    classDef infra fill:#1e293b,stroke:#a855f7,stroke-width:2px,color:#e2e8f0;
    classDef shared fill:#1e293b,stroke:#94a3b8,stroke-width:1px,stroke-dasharray: 5 5,color:#94a3b8;
    classDef actor fill:#000000,stroke:#fff,stroke-width:2px,color:#fff;
    classDef input fill:#0f172a,stroke:#64748b,stroke-width:1px,color:#94a3b8,stroke-dasharray: 2 2;

    %% 1. Inputs - Top Level
    User((Human Operator)):::actor
    World(World Context):::input

    %% 2. The Core
    JACQ(JACQ <br/><i>Cognitive OS</i>):::hub

    %% 3. Infrastructure Layer (Orchestration)
    subgraph Infrastructure
        Local(Local Compute<br/><i>Ollama / DuckDB</i>):::infra
        Cloud(Cloud Resources<br/><i>Vertex / Firebase</i>):::infra
        Tools(Tool Execution<br/><i>CLI / Browser / API</i>):::infra
    end

    %% 4. The App Federation (Outputs)
    Specter(Specter<br/><i>Autonomous Analyst</i>):::app
    BetSpecs(BetSpecs<br/><i>Real-Time Terminal</i>):::app
    
    %% 5. DNA
    Patterns[Shared Core Library<br/><i>Event Loops, Trust Validators</i>]:::shared

    %% Connection Logic - Vertical Flow
    User ==>|Intent| JACQ
    World -.->|Data & Events| JACQ
    
    JACQ ==>|Orchestrates| Infrastructure
    
    Local --- Cloud --- Tools
    
    Infrastructure ==>|Powers| Specter
    Infrastructure ==>|Powers| BetSpecs
    
    Specter -.->|Inherits| Patterns
    BetSpecs -.->|Inherits| Patterns

    %% Layout Hints
    linkStyle default stroke-width:2px,fill:none,stroke:#64748b;
